# Copy this file to docker/.env and fill in real values before running docker compose.
# docker/.env is git-ignored and must never be committed.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── SQL Server ───────────────────────────────────────────────────────────────
# Minimum complexity: 8+ chars, upper + lower + digit + symbol
SA_PASSWORD=Changeme1!

# ── Oracle Free ──────────────────────────────────────────────────────────────
ORACLE_PASSWORD=changeme          # SYS / SYSTEM password
ORACLE_APP_PASSWORD=changeme      # APP_USER "explorer" password

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme

# ── Exasol ───────────────────────────────────────────────────────────────────
EXASOL_SYS_PASSWORD=changeme
EXASOL_MEM_LIMIT=2GiB             # increase if host has more RAM available
